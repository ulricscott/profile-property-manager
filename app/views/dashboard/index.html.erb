<%= stylesheet_link_tag 'index' %>
<div class="container">
  <h1 class="display-5 mb-0">Klaviyo Tag Manager</h1>
  <div class="table-responsive">
    <table id="tag-table" class="table table-striped">
      <thead class="table-dark">
        <tr>
          <th class="border-0 fw-semibold">
            <input type="checkbox" id="select-all">
          </th>
          <th class="border-0 fw-semibold">ID</th>
          <th class="border-0 fw-semibold">Email</th>
          <th class="border-0 fw-semibold">Engagement</th>
        </tr>
      </thead>
      <tbody>
        <% @profiles.each_with_index do |profile, index| %>
          <tr>
            <td>
              <input type="checkbox" name="profile_selector" value="<%= profile[:id] %>" onclick="updateSelectedCount()">
            </td>
            <td class="border-0">
              <code class="text-secondary"><%= profile[:id] %></code>
            </td>
            <td class="border-0">
              <div class="d-flex align-items-center">
                <div>
                  <div class="fw-medium"><a href="mailto:<%= profile[:attributes][:email] %>"><%= profile[:attributes][:email] %></a></div>
                </div>
              </div>
            </td>
            <td class="border-0">
              <% engagement = profile[:attributes].try(:[], :properties).try(:[], :engagement) || '(none)'%>
              <% if engagement == ['very high'] %>
                <span class="badge bg-success"> Very High Engagement</span>
              <% elsif engagement == ['high'] %>
                <span class="badge bg-primary">High Engagement</span>
              <% elsif engagement == ['medium'] %>
                <span class="badge bg-info text-dark">Medium Engagement</span>
              <% elsif engagement == ['low'] %>
                <span class="badge bg-warning">Low Engagement</span>
              <% elsif engagement == ['very low'] %>
                <span class="badge bg-danger"> Very Low Engagement</span>
              <% else %>
                <span class="badge bg-secondary">Untagged</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <!-- Smart Cards -->
  <div class="row g-3 mb-4">
    <!-- Total Profile Count -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-primary fw-bold mb-1"><%= @profiles.count %></h3>
          <p class="text-muted mb-0 small">Total Profiles</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-success-emphasis fw-bold mb-1" id="selected-count">0</h3>
          <p class="text-muted mb-0 small">Selected</p>
        </div>
      </div>
    </div>
    <!-- Tagged Profiles Percentage -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <% 
            total_profiles = @profiles.count
            tagged_profiles = @profiles.select { |p| 
              engagement = p[:attributes].try(:[], :properties).try(:[], :engagement)
              ['very high', 'high', 'medium', 'low', 'very low'].include?(engagement.try(:first))
            }.count
            percentage = total_profiles > 0 ? ((tagged_profiles.to_f / total_profiles) * 100).round(1) : 0
          %>
          <h3 class="text-purple fw-bold mb-1"><%= percentage %>%</h3>
          <p class="text-muted mb-0 small">Tagged Profiles</p>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-3 mb-4">
    <!-- Very High Engagement Count -->
    <div class="col">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-success fw-bold mb-1"><%= @profiles.select { |p| p[:attributes].try(:[], :properties).try(:[], :engagement) == ['very high'] }.count %></h3>
          <p class="text-muted mb-0 small"> Very High Engagement</p>
        </div>
      </div>
    </div>
    <!-- High Engagement Count -->
    <div class="col">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-primary fw-bold mb-1"><%= @profiles.select { |p| p[:attributes].try(:[], :properties).try(:[], :engagement) == ['high'] }.count %></h3>
          <p class="text-muted mb-0 small">High Engagement</p>
        </div>
      </div>
    </div>
    <!-- Medium Engagement Count -->
    <div class="col">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-info fw-bold mb-1"><%= @profiles.select { |p| p[:attributes].try(:[], :properties).try(:[], :engagement) == ['medium'] }.count %></h3>
          <p class="text-muted mb-0 small">Medium Engagement</p>
        </div>
      </div>
    </div>
    <!-- Low Engagement Count -->
    <div class="col">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-warning fw-bold mb-1"><%= @profiles.select { |p| p[:attributes].try(:[], :properties).try(:[], :engagement) == ['low'] }.count %></h3>
          <p class="text-muted mb-0 small">Low Engagement</p>
        </div>
      </div>
    </div>
    <!-- Very Low Engagement Count -->
    <div class="col">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <h3 class="text-danger fw-bold mb-1"><%= @profiles.select { |p| p[:attributes].try(:[], :properties).try(:[], :engagement) == ['very low'] }.count %></h3>
          <p class="text-muted mb-0 small"> Very Low Engagement</p>
        </div>
      </div>
    </div>
  </div>
  <!-- MODAL TRIGGER -->
  <div class="float-end">
    <button id="export-csv-button" type="button" class="btn btn-secondary btn-lg rounded-pill shadow-lg px-4"onclick="exportCSV()">
      Export Full Table
    </button>
    <button id="add-tags-button" type="button" class="btn btn-primary btn-lg rounded-pill shadow-lg px-4" data-bs-toggle="modal" data-bs-target="#add-tags-modal" onclick="setProfilesInModal()">
      <i class="bi bi-tags me-2"></i>Add Tags
    </button>
  </div>
</div>
<!-- ADD TAGS MODAL -->
<div class="modal fade" id="add-tags-modal" tabindex="-1" aria-labelledby="addTagsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-secondary">
        <h5 class="modal-title fw-semibold text-white" id="addTagsModalLabel">Apply Tags</h5>
        <button type="button" class="btn-close btn-close-custom" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <h5 class="mb-3">Adding Tags To:</h5>
        <p id="selected-profiles"></p>
        <div class="mb-3">
          <label for="engagement_status" class="form-label">Tag</label>
          <!-- custom select drop down to allow for mock up pairiy but only passes along egagement status value "high", "low" -->
          <%= select_tag "engagement_status", options_for_select([
            ['Engagement: very high', 'very high'],
            ['Engagement: high', 'high'],
            ['Engagement: medium', 'medium'],
            ['Engagement: low', 'low'],
            ['Engagement: very low', 'very low'],
            ['Remove engagement tag', '']]),
            class: 'engagement-status-dropdown' %>
        </div>
      </div>
      <div class="modal-footer border-top">
        <button type="button" class="btn btn-light w-25" data-bs-dismiss="modal">
          Cancel
        </button>
        <button type="button" class="btn btn-primary w-25" onclick="updateSelectedProfiles()">
          OK
        </button>
      </div>
    </div>
  </div>
</div>